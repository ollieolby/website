---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Personal website, blog posts, and web apps by Ollie."
} = Astro.props;

const base = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <nav class="container nav">
          <a class="brand" href={`${base}/`}>
            <span class="brand-mark">OO</span>
            <span class="brand-copy">
              <strong>Ollie Olby</strong>
              <span>writing and products</span>
            </span>
          </a>

          <div class="nav-links">
            <a href={`${base}/`}>Home</a>
            <a href={`${base}/blog/`}>Blog</a>
            <a href={`${base}/apps/`}>Apps</a>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container footer-inner">
          <p>Personal site for notes, projects, and software experiments.</p>
          <p>Built with Astro and markdown.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
