---
import BaseLayout from "../layouts/BaseLayout.astro";

const apps = [
  {
    name: "Anagnost UI",
    description: "A standalone interface project hosted separately and linked from the main website.",
    liveUrl: "https://ollieolby.github.io/anagnost-ui/"
  }
];
---

<BaseLayout title="Apps | Ollie Olby" description="A directory of standalone web apps by Ollie Olby.">
  <section class="section-intro container">
    <p class="eyebrow">Apps</p>
    <h1>Projects</h1>
    <p class="lede">
      A small directory of standalone apps. Each one lives in its own repository and deploys
      independently, while this site stays focused on writing and discovery.
    </p>
  </section>

  <section class="container apps-grid">
    {apps.map((app) => (
      <article class="app-card">
        <p class="eyebrow">Live app</p>
        <h2><a href={app.liveUrl}>{app.name}</a></h2>
        <p>{app.description}</p>
        <a class="text-link" href={app.liveUrl}>Open app</a>
      </article>
    ))}
  </section>
</BaseLayout>
